<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Meals</title>

        <!-- Bootstrap CSS -->
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        />
    </head>
    <body class="bg-light">

        <div class="container py-5">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">Ovqatlar ro'yxati</h2>

                <!-- Modalni ochish tugmasi -->
                <button
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#mealModal"
                >
                    + Yangi taom
                </button>
            </div>

            <!-- Table -->
            <div class="card shadow-sm">
                <div class="card-body">

                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Nomi</th>
                                <th>Tarkibi</th>
                                <th>Kategoriyasi</th>
                            </tr>
                        </thead>

                        <tbody>
                            {{#each data}}
                                <tr>
                                    <td>{{this.name}}</td>
                                    <td>{{this.description}}</td>
                                    <td>{{this.c_name}}</td>
                                </tr>
                            {{/each}}
                        </tbody>
                    </table>

                </div>
            </div>

        </div>

        <!-- Modal -->
        <div class="modal fade" id="mealModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Yangi taom qo'shish</h5>
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                        ></button>
                    </div>

                    <form action="/meal" method="POST">

                        <div class="modal-body">

                            <div class="mb-3">
                                <label class="form-label">Ovqat nomi</label>
                                <input
                                    type="text"
                                    class="form-control"
                                    name="name"
                                    placeholder="Chuchvara"
                                />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Ovqat haqida</label>
                                <textarea
                                    class="form-control"
                                    name="description"
                                    rows="3"
                                ></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Kategoriya</label>
                                <select class="form-select" name="c_id">
                                    <option value="1">Milliy taom</option>
                                    <option value="2">Yevropa taomlari</option>
                                    <option value="3">Turk taomlari</option>
                                    <option value="4">Yapon taomlari</option>
                                    <option value="5">Fastfood</option>
                                </select>
                            </div>

                        </div>

                        <div class="modal-footer">
                            <button
                                type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal"
                            >
                                Bekor qilish
                            </button>
                            <button type="submit" class="btn btn-success">
                                Saqlash
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>

        <!-- Bootstrap JS -->
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        ></script>

    </body>
</html>